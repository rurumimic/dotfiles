# zmodload zsh/zprof # run zprof
# Lines configured by zsh-newuser-install
HISTFILE=~/.histfile
HISTSIZE=1000
SAVEHIST=1000
setopt autocd beep nomatch notify
unsetopt extendedglob
bindkey -e
# End of lines configured by zsh-newuser-install
# The following lines were added by compinstall
zstyle :compinstall filename '{{ joinPath .chezmoi.homeDir ".zshrc" }}'

autoload -Uz compinit
# Rebuild the completion dump at most once a day; otherwise load it with -C (skips
# the slow security/up-to-date check via compaudit). Compile the dump to .zwc
# bytecode so zsh sources it ~3x faster on every subsequent startup. extendedglob
# is enabled locally because this config unsets it globally, and (#q...) requires it.
# NOTE: compinit only rewrites the dump when completion functions change, so its
# mtime can stay frozen for months -> the mh+24 test stays true -> the slow path
# runs on *every* shell. touch resets the 24h timer so -C is actually used.
() {
  setopt local_options extendedglob
  local zcd=${ZDOTDIR:-$HOME}/.zcompdump
  if [[ -n $zcd(#qN.mh+24) ]]; then
    compinit -d "$zcd"
    touch "$zcd"
  else
    compinit -C -d "$zcd"
  fi
  if [[ -s $zcd && ( ! -s ${zcd}.zwc || $zcd -nt ${zcd}.zwc ) ]]; then
    zcompile -R -- "${zcd}.zwc" "$zcd"
  fi
}

autoload -U edit-command-line
zle -N edit-command-line
# emacs style
# bindkey '^xe' edit-command-line
bindkey '^x^e' edit-command-line
# vim style
bindkey -M viins '^x^e' edit-command-line
bindkey -M vicmd '^x^e' edit-command-line
bindkey -M vicmd v edit-command-line
# End of lines added by compinstall

